module simd_lane (
    input [31:0] a,
    input [31:0] b,
    input [1:0] opcode,
    output reg [31:0] result
);

always @(*) begin
    case(opcode)
        2'b00: result = a + b;
        2'b01: result = a - b;
        2'b10: result = a * b;
        default: result = 32'd0;
    endcase
end

endmodule

module vector_alu (
    input [127:0] vecA,
    input [127:0] vecB,
    input [1:0] opcode,
    output [127:0] result
);

genvar i;

generate
    for(i = 0; i < 4; i = i + 1) begin : lanes
        simd_lane lane (
            .a(vecA[i*32 +: 32]),
            .b(vecB[i*32 +: 32]),
            .opcode(opcode),
            .result(result[i*32 +: 32])
        );
    end
endgenerate

endmodule

