module vector_regfile (
    input clk,
    input we,
    input [2:0] rs1, rs2, rd,
    input [127:0] write_data,
    output [127:0] read_data1,
    output [127:0] read_data2
);

reg [127:0] regfile [0:7];

// Initialize registers (IMPORTANT for simulation)
integer i;
initial begin
    for(i = 0; i < 8; i = i + 1)
        regfile[i] = 128'd0;

    // preload test values
    regfile[0] = {32'd1,32'd2,32'd3,32'd4};
    regfile[1] = {32'd5,32'd6,32'd7,32'd8};
end

assign read_data1 = regfile[rs1];
assign read_data2 = regfile[rs2];

always @(posedge clk) begin
    if(we)
        regfile[rd] <= write_data;
end

endmodule


module control_unit (
    input [7:0] instruction,
    output reg [1:0] opcode,
    output reg [2:0] rs1, rs2, rd
);

always @(*) begin
    opcode = instruction[7:6];
    rs1    = instruction[5:3];
    rs2    = instruction[2:0];
    rd     = 3'b010;  // write to register 2 (better for testing)
end

endmodule


module top (
    input clk,
    input [7:0] instruction
);

wire [1:0] opcode;
wire [2:0] rs1, rs2, rd;

wire [127:0] vecA, vecB, result;

control_unit CU (
    .instruction(instruction),
    .opcode(opcode),
    .rs1(rs1),
    .rs2(rs2),
    .rd(rd)
);

vector_regfile VRF (
    .clk(clk),
    .we(1'b1),
    .rs1(rs1),
    .rs2(rs2),
    .rd(rd),
    .write_data(result),
    .read_data1(vecA),
    .read_data2(vecB)
);

vector_alu VALU (
    .vecA(vecA),
    .vecB(vecB),
    .opcode(opcode),
    .result(result)
);

endmodule


